      <div class="readonly-note hidden" id="readonlyNote">Nur ansehen – dieses Profil kann nicht bearbeitet werden.</div>
      <div class="profile-card"><div class="avatar-current" id="selectedAvatar">🌷</div><div class="profile-name" id="profileDisplayName">Maryam</div><div class="profile-age" id="profileDisplayAge">7 Jahre</div>
        <div class="fields">
          <label>Name<input id="nameField"></label>
