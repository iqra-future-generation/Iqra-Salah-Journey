<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#b7df72" />
  <meta name="description" content="Iqra Future Generation Salah Journey" />
  <title>Iqra Future Generation – Salah Journey</title>
  <style>
    :root{
      --bg1:#c9ea90;--bg2:#eef8df;--card:#fff;--green:#165b2a;--green2:#2f9c3e;
      --muted:#62656b;--line:#e2eadb;--shadow:0 12px 30px rgba(37,91,42,.13);--radius:26px;
    }
    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{margin:0;min-height:100vh;font-family:Arial,sans-serif;color:#18351f;
      background:radial-gradient(circle at 10% 8%,rgba(255,255,255,.55),transparent 24%),
      radial-gradient(circle at 92% 12%,rgba(255,255,255,.45),transparent 20%),
      linear-gradient(180deg,var(--bg1),var(--bg2))}
    button,input{font:inherit} button{cursor:pointer} a{color:inherit}.hidden{display:none!important}
    .app{max-width:920px;margin:auto;padding:18px 14px 120px}
    .topbar{display:grid;grid-template-columns:58px 1fr 58px;gap:12px;align-items:center}
    .round,.brand{background:#fff;box-shadow:var(--shadow);border:0}
    .round{width:56px;height:56px;border-radius:50%;font-size:26px;color:var(--green)}
    .brand{border-radius:22px;padding:15px;text-align:center;font-weight:900;font-size:clamp(20px,4vw,34px);color:var(--green)}
    .hero{text-align:center;padding:28px 8px 8px}.hero h1{font-size:clamp(38px,8vw,70px);line-height:1.02;margin:0;color:#0f5125}
    .date{margin-top:12px;color:#6a657b;font-size:clamp(18px,3vw,28px);font-weight:800}
    .stats{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin:24px 0}
    .stat,.section{background:#fff;border-radius:var(--radius);box-shadow:var(--shadow)}
    .stat{padding:20px 8px;text-align:center}.stat-icon{font-size:30px}
    .stat-value{font-size:clamp(42px,7vw,62px);font-weight:900;color:#0f5125;line-height:1}
    .stat-label{font-weight:800;color:#5e6265;font-size:20px;margin-top:8px}
    .section{padding:18px;margin-top:18px}.title{display:flex;align-items:center;gap:10px;font-size:clamp(24px,4vw,34px);font-weight:900;color:#164f27;margin:0 0 14px}
    .garden{min-height:300px;border-radius:22px;position:relative;overflow:hidden;background:linear-gradient(#94d9ff 0 65%,#74c948 65%);border:1px solid #d9eddf}
    .sun{position:absolute;right:10%;top:10%;width:64px;height:64px;border-radius:50%;background:#ffd53e;box-shadow:0 0 0 8px rgba(255,213,62,.25)}
    .cloud{position:absolute;background:#fff;border-radius:40px;width:90px;height:30px;top:18%;left:8%}
    .cloud:before,.cloud:after{content:"";position:absolute;background:#fff;border-radius:50%}.cloud:before{width:40px;height:40px;left:10px;top:-18px}.cloud:after{width:48px;height:48px;right:10px;top:-24px}
    .cloud.two{left:auto;right:18%;top:28%;transform:scale(.78)}
    .plant-wrap{position:absolute;left:50%;bottom:13%;transform:translateX(-50%);text-align:center}.plant{font-size:108px;filter:drop-shadow(0 8px 4px rgba(0,0,0,.12))}
    .soil{width:165px;height:50px;background:#71421f;border-radius:50%;margin:-22px auto 0;box-shadow:inset 0 -8px 0 rgba(0,0,0,.12)}
    .milestones{display:grid;grid-template-columns:repeat(6,1fr);gap:8px;margin-top:14px}.mile{text-align:center;color:#4b4d52;font-weight:800;font-size:13px}
    .mile-dot{width:50px;height:50px;border-radius:50%;margin:0 auto 6px;display:grid;place-items:center;background:#f2f2f2;border:2px solid #ddd;color:#777;font-size:22px}.mile.active .mile-dot{background:#fff;border-color:#2aa31e;color:#1a7c22}
    .message{text-align:center;color:#155325;font-weight:900;font-size:clamp(20px,3vw,28px);margin:16px 0 0}
    .prayers{display:grid;grid-template-columns:repeat(5,1fr);gap:8px}.prayer{border:2px solid #e8eddf;background:#fff;border-radius:20px;padding:12px 4px;text-align:center;transition:.18s}
    .prayer.checked{background:#effadf;border-color:#64bd45}.picon{font-size:38px}.pname{font-weight:900;color:#174d28;margin:6px 0}
    .check{width:30px;height:30px;border:3px solid #c9c6b8;border-radius:50%;margin:auto;display:grid;place-items:center}.checked .check{background:#53b839;border-color:#53b839;color:#fff}
    .bottom{display:grid;grid-template-columns:1fr 1fr;gap:16px}.rewardbox{background:#fff7d7;border-radius:20px;padding:16px;text-align:center}.bigstar{font-size:90px}
    .progress{display:flex;gap:18px;align-items:center}.ring{--p:0;width:145px;height:145px;border-radius:50%;display:grid;place-items:center;background:conic-gradient(#72c44d calc(var(--p)*1%),#e5f0d8 0)}
    .ring>div{width:112px;height:112px;border-radius:50%;background:#fff;display:grid;place-items:center;text-align:center}
    .month-table{width:100%;border-collapse:collapse;font-size:14px}.month-table th,.month-table td{padding:9px 6px;border-bottom:1px solid #edf0e9;text-align:center}.month-table th:first-child,.month-table td:first-child{text-align:left}
    .badge-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}.badge{background:#f7fbf3;border-radius:18px;padding:16px;text-align:center;border:2px solid #e3ebdc}.badge.locked{filter:grayscale(1);opacity:.55}.badge .emoji{font-size:42px}
    .card-link{display:block;text-decoration:none;text-align:center;padding:13px;border-radius:15px;font-weight:900;background:#eef8df;color:#165b2a}.card-link.facebook{background:#eaf2ff;color:#2456a4}
    .drawer-backdrop{position:fixed;inset:0;background:rgba(13,34,17,.42);opacity:0;visibility:hidden;transition:.25s;z-index:49}
    .drawer{position:fixed;top:0;left:0;width:min(340px,86vw);height:100%;padding:24px 18px;background:#fff;box-shadow:12px 0 35px rgba(0,0,0,.18);transform:translateX(-105%);transition:.28s;z-index:50;display:flex;flex-direction:column;gap:10px}
    .drawer.open{transform:translateX(0)}.drawer-backdrop.open{opacity:1;visibility:visible}.drawer-head{display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--line);padding-bottom:18px}
    .drawer-head strong{font-size:22px;color:var(--green)}.drawer-head small{display:block;color:#777;margin-top:4px}.drawer-close{width:42px;height:42px;border:0;border-radius:50%;background:#edf7df;color:var(--green);font-size:28px}
    .drawer-item{border:0;border-radius:16px;background:transparent;padding:15px;text-align:left;font-weight:900;font-size:18px;color:#29432f;text-decoration:none}.drawer-item:active{background:#eaf6d8}
    .drawer-footer{margin-top:auto;padding-top:18px;border-top:1px solid var(--line);text-align:center;color:#777;font-weight:800}
    .profile-page,.page{position:fixed;inset:0;z-index:70;overflow-y:auto;padding:18px 14px 80px;background:linear-gradient(180deg,#b7df72,#eef8df);transform:translateX(105%);transition:.28s}
    .profile-page.open,.page.open{transform:translateX(0)}.page-top{max-width:780px;margin:auto;display:flex;justify-content:space-between;align-items:center}
    .back{width:48px;height:48px;border:0;border-radius:50%;background:#fff;color:var(--green);font-size:25px;box-shadow:var(--shadow)}.page-title{font-size:28px;font-weight:900;color:var(--green)}
    .container{max-width:780px;margin:18px auto}.profile-card{background:#fff;border-radius:25px;padding:18px;margin-bottom:16px;box-shadow:var(--shadow)}.profile-heading{margin:0 0 14px;color:var(--green);font-size:22px}
    .avatar-current{width:110px;height:110px;border-radius:50%;display:grid;place-items:center;margin:0 auto 12px;background:#eef8df;font-size:60px}.profile-name{text-align:center;font-size:27px;font-weight:900;color:#174d28}.profile-age{text-align:center;color:#6a6c72;font-weight:800}
    .fields{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:16px}.fields label{font-weight:900;color:#36523d}.fields input{width:100%;margin-top:5px;padding:11px;border:2px solid #dfe9d7;border-radius:13px}
    .avatar-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:9px}.avatar-choice{border:2px solid transparent;border-radius:17px;background:#f3fae8;padding:9px 3px;font-size:34px}.avatar-choice.selected{border-color:#48a83d;background:#e0f5c8}
    .row{display:flex;justify-content:space-between;align-items:center;padding:12px;border-radius:14px;background:#f7fbf3;font-weight:900;margin:8px 0}
    .number-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}.number-box{background:#f7fbf3;border-radius:16px;padding:12px}.number-box label{display:block;font-weight:900;margin-bottom:6px}.number-box input{width:100%;padding:10px;border:2px solid #dfe9d7;border-radius:12px}
    .save{width:100%;border:0;border-radius:15px;padding:14px;background:#2f9c3e;color:#fff;font-weight:900;font-size:17px}
    .fields select{width:100%;margin-top:5px;padding:11px;border:2px solid #dfe9d7;border-radius:13px;background:#fff}
    .clickable-row{border:0;width:100%;color:inherit;text-align:left}.clickable-row:active{background:#e6f4d8}
    .batch-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}
    .batch-card{border:2px solid #e2ecd9;background:#fff;border-radius:20px;padding:18px;text-align:left;box-shadow:var(--shadow)}
    .batch-card strong{display:block;color:var(--green);font-size:21px}.batch-card span{display:block;color:#6b716c;margin-top:7px;font-weight:800}
    .student-list{display:grid;gap:10px}.student-row{display:flex;align-items:center;gap:12px;background:#f7fbf3;border:2px solid #e3ecd9;border-radius:18px;padding:12px}
    .student-open{flex:1;border:0;background:transparent;text-align:left;padding:0}.student-open strong{display:block;color:#174d28;font-size:18px}.student-open small{color:#727672}
    .student-avatar{width:48px;height:48px;border-radius:50%;display:grid;place-items:center;background:#eaf6d8;font-size:28px}
    .mini-delete{border:0;background:#fff0f0;color:#a72c2c;border-radius:12px;padding:9px 11px;font-weight:900}
    .batch-toolbar{display:flex;gap:10px;margin-bottom:14px}.batch-toolbar button{flex:1;border:0;border-radius:15px;padding:13px;font-weight:900}
    .add-student{background:#2f9c3e;color:#fff}.all-batches{background:#edf7df;color:#17602c}
    .nav{position:fixed;left:50%;bottom:10px;transform:translateX(-50%);width:min(880px,calc(100% - 20px));display:grid;grid-template-columns:repeat(5,1fr);background:#fff;border-radius:24px;box-shadow:0 8px 30px rgba(0,0,0,.15);padding:8px;z-index:20}
    .nav button{border:0;background:transparent;padding:8px;border-radius:16px;font-weight:800;color:#555}.nav button.active{background:#eaf6d8;color:#2b7b31}.ni{display:block;font-size:23px}
    .toast{position:fixed;left:50%;bottom:105px;transform:translateX(-50%) translateY(20px);background:#173f24;color:#fff;padding:12px 18px;border-radius:999px;opacity:0;pointer-events:none;transition:.25s;z-index:100}.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
    @media(max-width:650px){.app{padding-left:10px;padding-right:10px}.stats{gap:8px}.prayers{gap:5px}.picon{font-size:28px}.pname{font-size:13px}.bottom{grid-template-columns:1fr}.avatar-grid{grid-template-columns:repeat(4,1fr)}.fields,.number-grid{grid-template-columns:1fr}.milestones{grid-template-columns:repeat(3,1fr);row-gap:12px}.badge-grid{grid-template-columns:1fr 1fr}.batch-grid{grid-template-columns:1fr}}
  
    .auth-screen{position:fixed;inset:0;z-index:200;background:linear-gradient(180deg,#b7df72,#eef8df);display:grid;place-items:center;padding:18px}
    .auth-card{width:min(470px,100%);background:#fff;border-radius:28px;padding:26px;box-shadow:var(--shadow)}
    .auth-logo{text-align:center;font-size:58px}.auth-card h1{text-align:center;color:var(--green);margin:8px 0}
    .auth-card p{text-align:center;color:#68706a}.auth-card label,.modal-card label{display:block;font-weight:900;color:#36523d;margin-top:12px}
    .auth-card input,.modal-card input,.modal-card select{width:100%;margin-top:6px;padding:13px;border:2px solid #dfe9d7;border-radius:14px;background:#fff}
    .auth-submit{width:100%;margin-top:18px;border:0;border-radius:15px;padding:14px;background:#2f9c3e;color:#fff;font-weight:900}
    .auth-error{min-height:22px;color:#a72c2c;text-align:center;font-weight:800;margin-top:10px}
    .auth-note{font-size:13px!important}.logout{color:#a72c2c!important}
    .modal-backdrop{position:fixed;inset:0;z-index:160;background:rgba(13,34,17,.55);display:grid;place-items:center;padding:18px}
    .modal-card{width:min(520px,100%);max-height:92vh;overflow:auto;background:#fff;border-radius:26px;padding:22px;box-shadow:0 20px 50px rgba(0,0,0,.25)}
    .modal-title{display:flex;justify-content:space-between;align-items:center}.modal-title h2{margin:0;color:var(--green)}
    .modal-close{border:0;width:42px;height:42px;border-radius:50%;background:#edf7df;color:var(--green);font-size:25px}
    .readonly-note{background:#fff4cd;border:1px solid #ecd57b;border-radius:14px;padding:11px;margin-bottom:12px;text-align:center;font-weight:800;color:#755c00}
    .sync-pill{position:fixed;right:14px;top:14px;z-index:110;background:#fff;border-radius:999px;padding:8px 12px;box-shadow:var(--shadow);font-weight:800;color:#657068}
    .sync-pill.ok{color:#17602c}.sync-pill.bad{color:#a72c2c}
    .student-meta{color:#727672;font-size:13px;font-weight:800;margin-top:3px}

  
    .download-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
    .download-card{background:#fff;border-radius:24px;padding:18px;box-shadow:var(--shadow);text-align:center}
    .download-card img{width:100%;aspect-ratio:3/4;object-fit:cover;object-position:top;border-radius:18px;border:1px solid #e1ead9}
    .download-card h3{color:var(--green);margin:14px 0 6px}
    .download-actions{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:14px}
    .download-actions a{display:block;text-decoration:none;border-radius:14px;padding:12px 8px;font-weight:900}
    .pdf-open{background:#edf7df;color:#17602c}
    .pdf-download{background:#2f9c3e;color:#fff}
    @media(max-width:700px){.download-grid{grid-template-columns:1fr}}

  
    .teacher-dashboard{display:none;min-height:100vh;padding:18px 18px 110px;background:linear-gradient(180deg,#eef7df,#f8fbf3)}
    .teacher-dashboard.open{display:block}
    .teacher-top{max-width:1050px;margin:auto;display:flex;align-items:center;gap:14px}
    .teacher-top img{width:68px;height:68px;border-radius:18px;object-fit:cover;box-shadow:var(--shadow)}
    .teacher-top h1{margin:0;color:#174d28;font-size:clamp(27px,5vw,44px)}
    .teacher-top p{margin:5px 0 0;color:#667169;font-weight:800}
    .teacher-wrap{max-width:1050px;margin:18px auto 0}
    .teacher-summary{display:grid;grid-template-columns:repeat(5,1fr);gap:12px}
    .teacher-stat{background:#fff;border-radius:22px;padding:18px 12px;text-align:center;box-shadow:var(--shadow)}
    .teacher-stat .emoji{font-size:30px}.teacher-stat strong{display:block;font-size:31px;color:#17602c;margin-top:6px}
    .teacher-stat span{font-weight:800;color:#697169}
    .teacher-panel{background:#fff;border-radius:25px;padding:20px;margin-top:17px;box-shadow:var(--shadow)}
    .teacher-panel h2{margin:0 0 14px;color:#174d28}
    .teacher-description{width:100%;min-height:150px;padding:14px;border:2px solid #dfe9d7;border-radius:16px;font:inherit;resize:vertical;background:#fbfdf8}
    .teacher-save{border:0;border-radius:14px;padding:12px 18px;background:#2f9c3e;color:#fff;font-weight:900;margin-top:10px}
    .teacher-actions{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
    .teacher-action{border:0;border-radius:19px;padding:18px 10px;background:#edf7df;color:#17602c;font-weight:900;font-size:16px}
    .teacher-batches{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}
    .teacher-batch{border:2px solid #e2ecd9;background:#f9fcf5;border-radius:19px;padding:16px;text-align:left}
    .teacher-batch strong{font-size:20px;color:#174d28}.teacher-batch span{float:right;color:#6b716c;font-weight:900}
    .teacher-refresh{margin-left:auto;border:0;border-radius:14px;padding:11px 14px;background:#fff;color:#17602c;font-weight:900;box-shadow:var(--shadow)}
    @media(max-width:850px){.teacher-summary{grid-template-columns:repeat(2,1fr)}.teacher-actions{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:560px){.teacher-batches{grid-template-columns:1fr}.teacher-summary{grid-template-columns:1fr 1fr}.teacher-stat:last-child{grid-column:1/-1}}

  </style>

  <meta name="theme-color" content="#2f9c3e">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="Iqra Future">
  <link rel="manifest" href="manifest.webmanifest">
  <link rel="apple-touch-icon" href="apple-touch-icon.png">

</head>
<body>
  <div class="drawer-backdrop" id="drawerBackdrop"></div>
  <aside class="drawer" id="menuDrawer">
    <div class="drawer-head"><div><strong>🌱 Salah Journey</strong><small id="drawerName">Maryam</small></div><button class="drawer-close" id="closeDrawer">×</button></div>
    <button class="drawer-item" data-home>🏠 Home</button>
    <button class="drawer-item" data-scroll="#gardenSection">🌱 Mein Garten</button>
    <button class="drawer-item" data-scroll="#prayerSection">🕌 Gebete heute</button>
    <button class="drawer-item" id="drawerRewards">🎁 Belohnungen</button>
    <button class="drawer-item" id="drawerProfile">👤 Profil</button>
    <button class="drawer-item" id="drawerStudents">👩‍🏫 Batches & Schüler</button>
    <button class="drawer-item" id="drawerDownloads">📄 Salah-Tracker PDF</button>
    <button class="drawer-item logout" id="logoutButton">🚪 Abmelden</button>
    <a class="drawer-item" href="https://www.google.com/maps/search/?api=1&query=MDI+Center+Otto-Hahn-Stra%C3%9Fe+2+85609+Aschheim" target="_blank">🕌 MDI Center besuchen</a>
    <div class="drawer-footer">Iqra Future Generation<br>under Munich Dawah Initiative (MDI)</div>
  </aside>


  <section class="teacher-dashboard" id="teacherDashboard">
    <div class="teacher-top">
      <img src="iqra-logo.png" alt="Iqra Future Generation">
      <div>
        <h1>Assalamu alaikum, Teacher!</h1>
        <p>Iqra Future Generation · Admin Dashboard</p>
      </div>
      <button class="teacher-refresh" id="teacherRefresh">↻ Aktualisieren</button>
    </div>
    <div class="teacher-wrap">
      <section class="teacher-summary">
        <article class="teacher-stat"><div class="emoji">👧</div><strong id="teacherTotalStudents">0</strong><span>Schüler</span></article>
        <article class="teacher-stat"><div class="emoji">📚</div><strong id="teacherTotalBatches">7</strong><span>Batches</span></article>
        <article class="teacher-stat"><div class="emoji">🕌</div><strong id="teacherTodayUpdates">0</strong><span>Heute aktiv</span></article>
        <article class="teacher-stat"><div class="emoji">⭐</div><strong id="teacherMonthStars">0</strong><span>Sterne im Monat</span></article>
        <article class="teacher-stat"><div class="emoji">🌱</div><strong id="teacherActiveStudents">0</strong><span>Aktive Schüler</span></article>
      </section>

      <section class="teacher-panel">
        <h2>👩‍🏫 Unsere Lehrkräfte</h2>
        <p style="color:#68706a">Admins können hier Namen, Zuständigkeiten oder kurze Informationen über die Lehrkräfte eintragen.</p>
        <textarea class="teacher-description" id="teacherDescription" placeholder="Zum Beispiel:
Umm Maryam – Batch 1 und Batch 2
Umm Aisha – Batch 3
Vertretung: ..."></textarea>
        <button class="teacher-save" id="saveTeacherDescription">Beschreibung speichern</button>
      </section>

      <section class="teacher-panel">
        <h2>⚡ Schnellzugriff</h2>
        <div class="teacher-actions">
          <button class="teacher-action" id="teacherOpenBatches">👥 Batches & Schüler</button>
          <button class="teacher-action" id="teacherAddStudent">＋ Schüler hinzufügen</button>
          <button class="teacher-action" id="teacherOpenTrackers">📄 Salah-Tracker PDF</button>
          <button class="teacher-action" id="teacherLogout">🚪 Abmelden</button>
        </div>
      </section>

      <section class="teacher-panel">
        <h2>📚 Batches</h2>
        <div class="teacher-batches" id="teacherBatchGrid"></div>
      </section>
    </div>
  </section>

  <main class="app" id="studentApp">
    <header class="topbar"><button class="round" id="menuBtn">☰</button><div class="brand">🌱 MEIN SALAH GARTEN</div><button class="round" id="profileBtn">👤</button></header>
    <section class="hero"><h1>Assalamu alaikum,<br><span id="studentName">Maryam</span>!</h1><div class="date" id="todayDate"></div></section>
    <section class="stats">
      <article class="stat"><div class="stat-icon">📅</div><div class="stat-value" id="todayCount">0/5</div><div class="stat-label">Heute</div></article>
      <article class="stat"><div class="stat-icon">⭐</div><div class="stat-value" id="starCount">0</div><div class="stat-label">Sterne</div></article>
      <article class="stat"><div class="stat-icon">🌱</div><div class="stat-value" id="monthPercent">0%</div><div class="stat-label">Monat</div></article>
    </section>
    <section class="section" id="gardenSection">
      <h2 class="title">🌱 Mein wachsender Garten</h2>
      <div class="garden"><div class="cloud"></div><div class="cloud two"></div><div class="sun"></div><div class="plant-wrap"><div class="plant" id="plantEmoji">🌱</div><div class="soil"></div></div></div>
      <div class="milestones" id="milestones"></div><p class="message">Dein Garten wächst mit jedem Salah! 🌱</p>
    </section>
    <section class="section" id="prayerSection"><h2 class="title">🪴 Heutige Gebete</h2><div class="prayers" id="prayerList"></div><p class="message" style="font-size:18px;color:#6a6c72">🌸 Erledige alle 5 Salah und lass deinen Garten wachsen!</p></section>
    <section class="bottom">
      <article class="section"><h2 class="title">🎁 Belohnung</h2><div class="rewardbox"><div class="bigstar">⭐</div><div class="stat-value" id="rewardStars">0</div><div class="stat-label">Sterne</div></div></article>
      <article class="section"><h2 class="title">📅 Monatlicher Fortschritt</h2><div class="progress"><div class="ring" id="ring"><div><strong id="ringPct" style="font-size:38px">0%</strong><small>Diesen Monat</small></div></div><div><strong id="monthSalah">0</strong> / <span id="monthGoal">150</span> Salah<br><small id="remainingText">Noch 150</small></div></div></article>
    </section>
    <section class="section"><h2 class="title">🕌 MDI Center</h2><p><strong>Munich Dawah Initiative (MDI)</strong></p><p>Otto-Hahn-Straße 2<br>85609 Aschheim</p><a class="card-link" href="https://www.google.com/maps/search/?api=1&query=MDI+Center+Otto-Hahn-Stra%C3%9Fe+2+85609+Aschheim" target="_blank">📍 In Google Maps öffnen</a></section>
  </main>

  <nav class="nav" id="studentNav"><button class="active" id="navHome"><span class="ni">🏠</span>Home</button><button id="navGarden"><span class="ni">🌱</span>Garten</button><button id="navPrayers"><span class="ni">🕌</span>Gebete</button><button id="navRewards"><span class="ni">🎁</span>Belohnungen</button><button id="navProfile"><span class="ni">👤</span>Profil</button></nav>

  <section class="profile-page" id="profilePage">
    <div class="page-top"><button class="back" id="closeProfile">←</button><div class="page-title">Mein Profil</div><div style="width:48px"></div></div>
