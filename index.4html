      <div class="profile-card"><h3 class="profile-heading">📊 Mein Fortschritt</h3><div class="row"><span>🕌 Gesamte Salah</span><strong id="profileTotalSalah">0</strong></div><div class="row"><span>⭐ Sterne</span><strong id="profileTotalStars">0</strong></div><div class="row"><span>🌱 Garten-Level</span><strong id="profileGardenLevel">1</strong></div><button class="row clickable-row" id="profileBadgesButton"><span>🏆 Badges ansehen</span><strong id="profileBadgeCount">0 ›</strong></button></div>
      <div class="profile-card"><h3 class="profile-heading">📚 Lernfortschritt</h3><div class="number-grid"><div class="number-box"><label>📖 Gelernte Suren</label><input id="surahField" type="number" min="0" max="50"></div><div class="number-box"><label>🌸 Asmaul Husna</label><input id="asmaField" type="number" min="0" max="99"></div><div class="number-box"><label>📝 Qur'anische Wörter</label><input id="wordField" type="number" min="0" max="200"></div><div class="number-box"><label>🤲 Gelernte Duas</label><input id="duaField" type="number" min="0" max="100"></div></div></div>
      <div class="profile-card"><h3 class="profile-heading">💚 Contact Us</h3><a class="card-link facebook" id="facebookLink" href="https://www.facebook.com/profile.php?id=100078858246868" target="_blank">📘 Iqra Future Generation Facebook Page</a><p id="facebookHint" style="text-align:center;color:#777;margin-bottom:0">Öffnet unsere Facebook-Seite.</p></div>
      <button class="save" id="saveProfile">Profil speichern</button>
    </div>
