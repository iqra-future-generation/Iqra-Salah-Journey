  <div class="toast" id="toast"></div>


  <script src="https://www.gstatic.com/firebasejs/10.12.5/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.12.5/firebase-auth-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.12.5/firebase-firestore-compat.js"></script>
  <script>
    const firebaseConfig = {
      apiKey: "AIzaSyC__eu40QqbyP38WHjAfhdBlp7Eep7P4lI",
      authDomain: "iqra-salah-journey-5deb8.firebaseapp.com",
      projectId: "iqra-salah-journey-5deb8",
      storageBucket: "iqra-salah-journey-5deb8.firebasestorage.app",
      messagingSenderId: "627621711954",
      appId: "1:627621711954:web:e213674d91b5635b124f8b"
    };
    const ADMIN_EMAIL = "teacher.iqra2023@gmail.com";
    const FACEBOOK_URL = "https://www.facebook.com/profile.php?id=100078858246868";
    const BATCHES=["Batch 1","Batch 2","Batch 3","Batch 4","Batch 5","Batch 6","Batch 7"];
    const DEFAULT_INVITE_CODES={"Batch 1": "IQRA-1-DCSSGY", "Batch 2": "IQRA-2-BAU3B2", "Batch 3": "IQRA-3-9PWWU4", "Batch 4": "IQRA-4-LJ6HSF", "Batch 5": "IQRA-5-MCU7TK", "Batch 6": "IQRA-6-B9YDE5", "Batch 7": "IQRA-7-3U3JJC"};
    const PRAYERS=[{key:"fajr",name:"Fajr",icon:"🌙"},{key:"dhuhr",name:"Dhuhr",icon:"☀️"},{key:"asr",name:"Asr",icon:"🌤️"},{key:"maghrib",name:"Maghrib",icon:"🌅"},{key:"isha",name:"Isha",icon:"🌌"}];
    const MILESTONES=[{at:0,label:"Tag 1",icon:"🌱"},{at:10,label:"10 Salah",icon:"🌿"},{at:50,label:"50 Salah",icon:"🪴"},{at:100,label:"100 Salah",icon:"🌳"},{at:200,label:"200 Salah",icon:"🌸"},{at:500,label:"500 Salah",icon:"✨"}];
    const BADGES=[{at:1,icon:"🌱",name:"Erster Schritt"},{at:10,icon:"🌿",name:"10 Salah"},{at:50,icon:"🪴",name:"50 Salah"},{at:100,icon:"🌳",name:"100 Salah"},{at:200,icon:"🌸",name:"200 Salah"},{at:500,icon:"✨",name:"500 Salah"}];
    const AVATARS=["🌹","🌷","🌻","🌼","🌺","🪻","🌱","🌳","🌴","🌲","🍃","🌿","🍎","🍓","🍉","🍊","🍌","🍇","🚗","🚂","🚲","✈️","🚜","🚢","☀️","🌙","⭐","🏔️","☁️","🌊","🕌","🏮"];

    const $=id=>document.getElementById(id);
    const els={};
    ["drawerBackdrop","menuDrawer","drawerName","closeDrawer","drawerRewards","drawerProfile","drawerStudents","drawerDownloads","logoutButton","menuBtn","profileBtn","studentName","todayDate","todayCount","starCount","monthPercent","gardenSection","plantEmoji","milestones","prayerSection","prayerList","rewardStars","ring","ringPct","monthSalah","monthGoal","remainingText","navHome","navGarden","navPrayers","navRewards","navProfile","profilePage","closeProfile","selectedAvatar","profileDisplayName","profileDisplayAge","nameField","ageField","batchField","parentField","avatarGrid","profileTotalSalah","profileTotalStars","profileGardenLevel","profileBadgesButton","profileBadgeCount","surahField","asmaField","wordField","duaField","facebookLink","facebookHint","saveProfile","readonlyNote","studentsPage","closeStudents","downloadsPage","closeDownloads","studentsPageTitle","showAllBatches","addStudentButton","batchGrid","studentList","emptyBatch","rewardsPage","closeRewards","rewardPageStars","badgeGrid","monthTable","toast","authScreen","loginForm","loginEmail","loginPassword","loginButton","openSignupButton","loginError","signupModal","signupForm","closeSignupModal","signupStudentName","signupStudentAge","signupBatch","signupInviteCode","signupStudentId","signupPassword","signupPassword2","signupParentName","signupSubmitButton","signupError","studentModal","studentForm","closeStudentModal","newStudentName","newStudentAge","newStudentBatch","newStudentEmail","newStudentPassword","newStudentParent","createStudentButton","studentFormError","syncPill","teacherDashboard","studentApp","studentNav","teacherRefresh","teacherTotalStudents","teacherTotalBatches","teacherTodayUpdates","teacherMonthStars","teacherActiveStudents","teacherDescription","saveTeacherDescription","teacherOpenBatches","teacherAddStudent","teacherOpenTrackers","teacherLogout","teacherBatchGrid"].forEach(id=>els[id]=$(id));
    Object.assign(window,els);

    firebase.initializeApp(firebaseConfig);
    const auth=firebase.auth();
    auth.setPersistence(firebase.auth.Auth.Persistence.LOCAL).catch(console.error);
    const db=firebase.firestore();
    let secondaryApp=null, secondaryAuth=null;

    let currentUser=null;
    let isAdmin=false;
    let ownState=null;
    let displayState=null;
    let viewingOwn=true;
    let selectedBatch=null;
    let batchMembers=[];
    let batchProgress=new Map();

    const emptyState=(uid,name="Schüler",batch="Batch 1")=>({
      id:uid,name,batch,role:"student",studentId:"",
      profile:{age:7,parent:"",avatar:"🌷",surahs:0,asma:0,words:0,duas:0},
      records:{},stars:0
    });

    const dateKey=(d=new Date())=>d.toLocaleDateString("en-CA");
    const monthKey=(d=new Date())=>`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}`;
    const daysInMonth=(d=new Date())=>new Date(d.getFullYear(),d.getMonth()+1,0).getDate();
    const totalCompleted=s=>Object.values(s?.records||{}).reduce((sum,r)=>sum+PRAYERS.filter(p=>r?.[p.key]).length,0);
    const monthCompleted=s=>Object.entries(s?.records||{}).filter(([k])=>k.startsWith(monthKey())).reduce((sum,[,r])=>sum+PRAYERS.filter(p=>r?.[p.key]).length,0);
    const levelFor=t=>t>=500?6:t>=200?5:t>=100?4:t>=50?3:t>=10?2:1;
    const plantFor=t=>t>=500?"🌟":t>=200?"🌸":t>=100?"🌳":t>=50?"🪴":t>=10?"🌿":"🌱";
    const badgeCount=s=>BADGES.filter(b=>totalCompleted(s)>=b.at).length;
    const escapeHtml=v=>String(v??"").replace(/[&<>"']/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#039;"}[c]));
    const STUDENT_LOGIN_DOMAIN="iqra.local";
    function normalizeStudentId(value){
      return String(value||"").trim().toLowerCase().replace(/\s+/g,"-").replace(/[^a-z0-9._-]/g,"");
    }
    function loginIdentifierToEmail(value){
      const v=String(value||"").trim().toLowerCase();
      return v.includes("@") ? v : `${normalizeStudentId(v)}@${STUDENT_LOGIN_DOMAIN}`;
    }


    function showToast(message){
      toast.textContent=message;toast.classList.add("show");
      setTimeout(()=>toast.classList.remove("show"),2200);
    }
    function setSync(text,status=""){
      syncPill.textContent=text;syncPill.className="sync-pill "+status;
      syncPill.classList.remove("hidden");
      if(status==="ok")setTimeout(()=>syncPill.classList.add("hidden"),1300);
    }
    function friendlyError(error){
      const code=error?.code||"";
      if(code.includes("invalid-credential")||code.includes("wrong-password")||code.includes("user-not-found"))return "E-Mail oder Passwort ist falsch.";
      if(code.includes("email-already-in-use"))return "Diese Student-ID wird bereits verwendet.";
      if(code.includes("invalid-email"))return "Bitte eine gültige Student-ID eingeben."
      if(code.includes("weak-password"))return "Das Passwort muss mindestens 6 Zeichen haben.";
      if(code.includes("unauthorized-domain"))return "Diese Website-Domain muss in Firebase Authentication freigegeben werden.";
      if(code.includes("permission-denied"))return "Keine Berechtigung für diese Aktion.";
      return error?.message||"Etwas ist schiefgelaufen.";
    }

    function memberFromDoc(doc){
      const d=doc.data()||{};
      return {id:doc.id,name:d.name||"Schüler",batch:d.batch||"Batch 1",role:d.role||"student",studentId:d.studentId||"",
        profile:{age:Number(d.age)||7,parent:"",avatar:d.avatar||"🌷",surahs:0,asma:0,words:0,duas:0},records:{},stars:0};
    }
    function mergeProgress(state,data={}){
      state.records=data.records||{};
      state.stars=Number(data.stars)||0;
      state.profile.surahs=Number(data.surahs)||0;
      state.profile.asma=Number(data.asma)||0;
      state.profile.words=Number(data.words)||0;
      state.profile.duas=Number(data.duas)||0;
      return state;
    }

    async function loadStudent(uid,{includePrivate=false}={}){
      const [memberSnap,progressSnap]=await Promise.all([
        db.collection("members").doc(uid).get(),
        db.collection("progress").doc(uid).get()
      ]);
      if(!memberSnap.exists)throw new Error("Profil wurde noch nicht eingerichtet.");
      const s=memberFromDoc(memberSnap);
      if(progressSnap.exists)mergeProgress(s,progressSnap.data());
      if(includePrivate){
        try{
          const privateSnap=await db.collection("privateProfiles").doc(uid).get();
          if(privateSnap.exists)s.profile.parent=privateSnap.data().parent||"";
        }catch(_){}
      }
      return s;
    }

    async function bootstrapAdmin(user){
      const ref=db.collection("members").doc(user.uid);
      const snap=await ref.get();
      if(!snap.exists){
        await ref.set({name:"Iqra Teacher",age:18,avatar:"🌿",batch:"Admin",role:"admin",email:user.email});
        await db.collection("progress").doc(user.uid).set({userId:user.uid,batch:"Admin",records:{},stars:0,surahs:0,asma:0,words:0,duas:0});
        await db.collection("privateProfiles").doc(user.uid).set({parent:""});
      }
      for(const batch of BATCHES){
        const ref=db.collection("inviteCodes").doc(batch.replace(" ","-").toLowerCase());
        const snap=await ref.get();
        if(!snap.exists){
          await ref.set({batch,code:DEFAULT_INVITE_CODES[batch],active:true});
        }
      }
    }


    function currentMonthStars(records={}){
      return Object.entries(records)
        .filter(([key])=>key.startsWith(monthKey()))
        .reduce((sum,[,record])=>{
          const count=PRAYERS.filter(p=>record?.[p.key]).length;
          return sum + count + (count===5 ? 5 : 0);
        },0);
    }

    async function loadTeacherDashboard(){
      if(!isAdmin)return;
      setSync("Dashboard laden…");
      try{
        const [membersSnap,progressSnap,settingsSnap]=await Promise.all([
          db.collection("members").where("role","==","student").get(),
          db.collection("progress").get(),
          db.collection("settings").doc("teacherDashboard").get()
        ]);
        const students=membersSnap.docs.map(memberFromDoc);
        const progressMap=new Map(progressSnap.docs.map(d=>[d.id,d.data()]));
        const today=dateKey();
        let todayActive=0,activeStudents=0,monthStars=0;

        students.forEach(student=>{
          const progress=progressMap.get(student.id)||{};
          const records=progress.records||{};
          const todayRecordData=records[today]||{};
          if(PRAYERS.some(p=>todayRecordData[p.key]))todayActive++;
          if(Object.keys(records).some(key=>key.startsWith(monthKey()) && PRAYERS.some(p=>records[key]?.[p.key])))activeStudents++;
          monthStars+=currentMonthStars(records);
        });

        teacherTotalStudents.textContent=students.length;
        teacherTotalBatches.textContent=BATCHES.length;
        teacherTodayUpdates.textContent=todayActive;
        teacherMonthStars.textContent=monthStars;
        teacherActiveStudents.textContent=activeStudents;
        teacherDescription.value=settingsSnap.exists ? (settingsSnap.data().description||"") : "";

        const counts={};BATCHES.forEach(b=>counts[b]=0);
        students.forEach(s=>{if(counts[s.batch]!==undefined)counts[s.batch]++});
        teacherBatchGrid.innerHTML="";
        BATCHES.forEach(batch=>{
          const button=document.createElement("button");
          button.className="teacher-batch";
          button.innerHTML=`<strong>📁 ${batch}</strong><span>${counts[batch]} Schüler ›</span>`;
          button.onclick=async()=>{await openStudents();await openBatch(batch)};
          teacherBatchGrid.appendChild(button);
        });
        setSync("Aktuell","ok");
      }catch(error){
        setSync("Fehler","bad");
        showToast(friendlyError(error));
      }
    }

    async function saveTeacherDescriptionData(){
      if(!isAdmin)return;
      setSync("Speichern…");
      try{
        await db.collection("settings").doc("teacherDashboard").set({
          description:teacherDescription.value.trim(),
          updatedAt:firebase.firestore.FieldValue.serverTimestamp(),
          updatedBy:currentUser.email
        },{merge:true});
        setSync("Gespeichert","ok");
        showToast("Lehrerbeschreibung gespeichert ✓");
      }catch(error){
        setSync("Fehler","bad");
        showToast(friendlyError(error));
      }
    }

    function showTeacherDashboard(){
      teacherDashboard.classList.add("open");
      studentApp.style.display="none";
      studentNav.style.display="none";
      profilePage.classList.remove("open");
      studentsPage.classList.remove("open");
      rewardsPage.classList.remove("open");
      downloadsPage.classList.remove("open");
      loadTeacherDashboard();
    }

    function showStudentExperience(){
      teacherDashboard.classList.remove("open");
      studentApp.style.display="";
      studentNav.style.display="";
    }

    async function initializeSession(user){
      currentUser=user;
      isAdmin=(user.email||"").toLowerCase()===ADMIN_EMAIL.toLowerCase();
      setSync("Daten laden…");
      if(isAdmin)await bootstrapAdmin(user);
      ownState=await loadStudent(user.uid,{includePrivate:true});
      displayState=ownState;viewingOwn=true;
      authScreen.classList.add("hidden");
      drawerStudents.textContent=isAdmin?"👩‍🏫 Batches & Schüler":"👥 Meine Gruppe";
      addStudentButton.classList.toggle("hidden",!isAdmin);
      render();
      setSync("Aktuell","ok");
      if(isAdmin){showTeacherDashboard()}else{showStudentExperience()}
    }

    function todayRecord(){
      const k=dateKey();
      if(!displayState.records[k])displayState.records[k]={};
      return displayState.records[k];
    }

    function canEditDisplayed(){
      return isAdmin || (currentUser && displayState?.id===currentUser.uid);
    }

    function render(){
      if(!displayState)return;
      studentName.textContent=displayState.name;
      drawerName.textContent=`${displayState.name} · ${displayState.batch}`;
      todayDate.textContent=new Date().toLocaleDateString("de-DE",{weekday:"long",day:"2-digit",month:"long",year:"numeric"});
      const rec=todayRecord();
      const today=PRAYERS.filter(p=>rec[p.key]).length;
      const month=monthCompleted(displayState),goal=daysInMonth()*5;
      const pct=Math.min(100,Math.round(month/goal*100)),total=totalCompleted(displayState);
      todayCount.textContent=`${today}/5`;starCount.textContent=displayState.stars;
      rewardStars.textContent=displayState.stars;rewardPageStars.textContent=displayState.stars;
      monthPercent.textContent=`${pct}%`;ringPct.textContent=`${pct}%`;ring.style.setProperty("--p",pct);
      monthSalah.textContent=month;monthGoal.textContent=goal;remainingText.textContent=`Noch ${Math.max(0,goal-month)}`;
      plantEmoji.textContent=plantFor(total);
      prayerList.innerHTML="";
      PRAYERS.forEach(p=>{
        const b=document.createElement("button");
        b.className="prayer"+(rec[p.key]?" checked":"");
        b.disabled=!canEditDisplayed();
        b.innerHTML=`<div class="picon">${p.icon}</div><div class="pname">${p.name}</div><div class="check">${rec[p.key]?"✓":""}</div>`;
        b.onclick=()=>togglePrayer(p.key);prayerList.appendChild(b);
      });
      milestones.innerHTML="";
      MILESTONES.forEach(m=>{
        const e=document.createElement("div");e.className="mile"+(total>=m.at?" active":"");
        e.innerHTML=`<div class="mile-dot">${total>=m.at?m.icon:"🔒"}</div><div>${m.label}</div>`;milestones.appendChild(e);
      });
    }

    async function saveProgress(s){
      setSync("Speichern…");
      await db.collection("progress").doc(s.id).set({
        userId:s.id,batch:s.batch,records:s.records||{},stars:Number(s.stars)||0,
        surahs:Number(s.profile.surahs)||0,asma:Number(s.profile.asma)||0,
        words:Number(s.profile.words)||0,duas:Number(s.profile.duas)||0,
        updatedAt:firebase.firestore.FieldValue.serverTimestamp()
      },{merge:true});
      if(ownState?.id===s.id)ownState=s;
      setSync("Gespeichert","ok");
    }

    async function togglePrayer(key){
      if(!canEditDisplayed())return;
      const r=todayRecord(),before=PRAYERS.filter(p=>r[p.key]).length;
      r[key]=!r[key];
      const after=PRAYERS.filter(p=>r[p.key]).length;
      if(after>before){displayState.stars+=1;if(after===5&&before!==5)displayState.stars+=5}
      else{displayState.stars=Math.max(0,displayState.stars-1);if(before===5&&after!==5)displayState.stars=Math.max(0,displayState.stars-5)}
      render();
      try{await saveProgress(displayState)}catch(e){showToast(friendlyError(e))}
    }

    const openDrawer=()=>{menuDrawer.classList.add("open");drawerBackdrop.classList.add("open")};
    const closeDrawerFn=()=>{menuDrawer.classList.remove("open");drawerBackdrop.classList.remove("open")};

    function buildAvatarGrid(editable){
      avatarGrid.innerHTML="";
      AVATARS.forEach(a=>{
        const b=document.createElement("button");b.type="button";
        b.className="avatar-choice"+(displayState.profile.avatar===a?" selected":"");
        b.textContent=a;b.disabled=!editable;
        b.onclick=()=>{displayState.profile.avatar=a;selectedAvatar.textContent=a;buildAvatarGrid(editable)};
        avatarGrid.appendChild(b);
      });
    }

    async function openProfileFor(student,editable,includePrivate=false){
      closeDrawerFn();studentsPage.classList.remove("open");
      displayState=student;
      viewingOwn=student.id===currentUser.uid;
      if(includePrivate && !student.profile.parent){
        try{
          const ps=await db.collection("privateProfiles").doc(student.id).get();
          if(ps.exists)student.profile.parent=ps.data().parent||"";
        }catch(_){}
      }
      nameField.value=student.name;ageField.value=student.profile.age;batchField.value=student.batch;
      parentField.value=student.profile.parent||"";surahField.value=student.profile.surahs;asmaField.value=student.profile.asma;
      wordField.value=student.profile.words;duaField.value=student.profile.duas;
      profileDisplayName.textContent=student.name;profileDisplayAge.textContent=`${student.profile.age} Jahre · ${student.batch}`;
      selectedAvatar.textContent=student.profile.avatar;profileTotalSalah.textContent=totalCompleted(student);
      profileTotalStars.textContent=student.stars;profileGardenLevel.textContent=levelFor(totalCompleted(student));
      profileBadgeCount.textContent=`${badgeCount(student)} ›`;
      readonlyNote.classList.toggle("hidden",editable);
      [nameField,ageField,parentField,surahField,asmaField,wordField,duaField].forEach(x=>x.disabled=!editable);
      batchField.disabled=!isAdmin;
      saveProfile.classList.toggle("hidden",!editable);
      buildAvatarGrid(editable);
      profilePage.classList.add("open");
    }

    function openOwnProfile(){
      displayState=ownState;render();
      openProfileFor(ownState,true,true);
    }

    async function saveProfileData(){
      if(!canEditDisplayed())return;
      const newBatch=isAdmin?batchField.value:displayState.batch;
      displayState.name=nameField.value.trim()||"Schüler";
      displayState.batch=newBatch;
      displayState.profile.age=Math.max(3,Number(ageField.value)||7);
      displayState.profile.parent=parentField.value.trim();
      displayState.profile.surahs=Math.max(0,Number(surahField.value)||0);
      displayState.profile.asma=Math.max(0,Number(asmaField.value)||0);
      displayState.profile.words=Math.max(0,Number(wordField.value)||0);
      displayState.profile.duas=Math.max(0,Number(duaField.value)||0);
      setSync("Speichern…");
      try{
        await db.collection("members").doc(displayState.id).set({
          name:displayState.name,age:displayState.profile.age,avatar:displayState.profile.avatar,
          batch:displayState.batch,role:displayState.role||"student"
        },{merge:true});
        await db.collection("privateProfiles").doc(displayState.id).set({parent:displayState.profile.parent},{merge:true});
        await saveProgress(displayState);
        if(displayState.id===currentUser.uid)ownState=displayState;
        render();showToast("Profil gespeichert ✓");
        await openProfileFor(displayState,true,true);
      }catch(e){setSync("Fehler","bad");showToast(friendlyError(e))}
    }

    async function queryBatch(batch){
      const membersQuery=isAdmin && batch==="__all__"
        ? db.collection("members").where("role","==","student")
        : db.collection("members").where("batch","==",batch);
      const progressQuery=isAdmin && batch==="__all__"
        ? db.collection("progress")
        : db.collection("progress").where("batch","==",batch);
      const [ms,ps]=await Promise.all([membersQuery.get(),progressQuery.get()]);
      batchMembers=ms.docs.filter(d=>(d.data().role||"student")==="student").map(memberFromDoc);
      batchProgress=new Map(ps.docs.map(d=>[d.id,d.data()]));
      batchMembers.forEach(s=>{if(batchProgress.has(s.id))mergeProgress(s,batchProgress.get(s.id))});
      return batchMembers;
    }

    async function renderBatchOverview(){
      selectedBatch=null;studentsPageTitle.textContent=isAdmin?"Batches & Schüler":"Meine Gruppe";
      batchGrid.classList.remove("hidden");studentList.classList.add("hidden");emptyBatch.classList.add("hidden");
      showAllBatches.classList.add("hidden");addStudentButton.classList.add("hidden");
      batchGrid.innerHTML="";
      if(!isAdmin){await openBatch(ownState.batch);return}
      setSync("Batches laden…");
      const all=await db.collection("members").where("role","==","student").get();
      const counts={};BATCHES.forEach(b=>counts[b]=0);
      all.docs.forEach(d=>{const b=d.data().batch;if(counts[b]!==undefined)counts[b]++});
      BATCHES.forEach(batch=>{
        const b=document.createElement("button");b.className="batch-card";
        b.innerHTML=`<strong>📁 ${batch}</strong><span>${counts[batch]} Schüler ›</span>`;
        b.onclick=()=>openBatch(batch);batchGrid.appendChild(b);
      });
      setSync("Aktuell","ok");
    }

    async function openStudents(){
      closeDrawerFn();profilePage.classList.remove("open");rewardsPage.classList.remove("open");
      displayState=ownState;render();studentsPage.classList.add("open");
      try{await renderBatchOverview()}catch(e){showToast(friendlyError(e))}
    }

    async function openBatch(batch){
      selectedBatch=batch;studentsPageTitle.textContent=batch;
      batchGrid.classList.add("hidden");studentList.classList.remove("hidden");
      showAllBatches.classList.toggle("hidden",!isAdmin);
      addStudentButton.classList.toggle("hidden",!isAdmin);
      studentList.innerHTML="";emptyBatch.classList.add("hidden");
      setSync("Schüler laden…");
      try{
        const students=await queryBatch(batch);
        emptyBatch.classList.toggle("hidden",students.length>0);
        students.sort((a,b)=>a.name.localeCompare(b.name,"de")).forEach(s=>{
          const row=document.createElement("div");row.className="student-row";
          const total=totalCompleted(s);
          row.innerHTML=`<div class="student-avatar">${s.profile.avatar||"🌷"}</div>
            <button class="student-open"><strong>${escapeHtml(s.name)}</strong>
            <div class="student-meta">${s.studentId?`🪪 ${escapeHtml(s.studentId)} · `:""}⭐ ${s.stars} · 🕌 ${total} Salah · 🌱 Level ${levelFor(total)}</div></button>
            ${isAdmin?'<button class="mini-delete" title="Profil-Daten löschen">🗑️</button>':''}`;
          row.querySelector(".student-open").onclick=async()=>{
            const full=await loadStudent(s.id,{includePrivate:isAdmin});
            await openProfileFor(full,isAdmin||s.id===currentUser.uid,isAdmin||s.id===currentUser.uid);
          };
          if(isAdmin)row.querySelector(".mini-delete").onclick=()=>deleteStudentData(s);
          studentList.appendChild(row);
        });
        setSync("Aktuell","ok");
      }catch(e){setSync("Fehler","bad");showToast(friendlyError(e))}
    }

    async function deleteStudentData(s){
      if(!isAdmin||!confirm(`${s.name}s Profildaten wirklich löschen? Das Login-Konto bleibt in Authentication bestehen.`))return;
      try{
        await Promise.all([
          db.collection("members").doc(s.id).delete(),
          db.collection("progress").doc(s.id).delete(),
          db.collection("privateProfiles").doc(s.id).delete()
        ]);
        showToast("Profildaten gelöscht");await openBatch(selectedBatch);
      }catch(e){showToast(friendlyError(e))}
    }

    function showStudentModal(){
      if(!isAdmin)return;
      studentForm.reset();newStudentAge.value=7;newStudentBatch.value=selectedBatch||"Batch 1";
      studentFormError.textContent="";studentModal.classList.remove("hidden");
    }

    async function createStudentAccount(event){
      event.preventDefault();if(!isAdmin)return;
      studentFormError.textContent="";createStudentButton.disabled=true;createStudentButton.textContent="Erstellen…";
      const name=newStudentName.value.trim(),age=Number(newStudentAge.value)||7,batch=newStudentBatch.value;
      const studentId=normalizeStudentId(newStudentEmail.value),email=`${studentId}@${STUDENT_LOGIN_DOMAIN}`,password=newStudentPassword.value,parent=newStudentParent.value.trim();
      let createdUser=null;
      try{
        if(!secondaryApp){
          secondaryApp=firebase.initializeApp(firebaseConfig,"StudentCreator");
          secondaryAuth=secondaryApp.auth();
        }
        const cred=await secondaryAuth.createUserWithEmailAndPassword(email,password);
        createdUser=cred.user;
        const uid=createdUser.uid;
        await db.collection("members").doc(uid).set({name,age,avatar:"🌷",batch,role:"student",studentId,email});
        await db.collection("progress").doc(uid).set({userId:uid,batch,records:{},stars:0,surahs:0,asma:0,words:0,duas:0});
        await db.collection("privateProfiles").doc(uid).set({parent});
        await secondaryAuth.signOut();
        studentModal.classList.add("hidden");alert(`Schülerkonto erstellt!\n\nStudent-ID: ${studentId}\nPasswort: ${password}\n\nBitte diese Zugangsdaten sicher an die Eltern weitergeben.`);showToast("Schülerkonto erstellt ✓");await openBatch(batch);
      }catch(e){
        if(createdUser){try{await createdUser.delete()}catch(_){}}
        studentFormError.textContent=friendlyError(e);
      }finally{
        createStudentButton.disabled=false;createStudentButton.textContent="Konto erstellen";
      }
    }

    function buildRewards(){
      const s=displayState||ownState,total=totalCompleted(s);
      badgeGrid.innerHTML="";
      BADGES.forEach(b=>{const e=document.createElement("div");e.className="badge"+(total<b.at?" locked":"");e.innerHTML=`<div class="emoji">${total>=b.at?b.icon:"🔒"}</div><strong>${b.name}</strong>`;badgeGrid.appendChild(e)});
      const d=new Date(),days=daysInMonth(d);let h="<tr><th>Tag</th>"+PRAYERS.map(p=>`<th>${p.name}</th>`).join("")+"</tr>";
      for(let day=1;day<=days;day++){const k=`${monthKey(d)}-${String(day).padStart(2,"0")}`,r=s.records[k]||{};h+=`<tr><td>${day}</td>${PRAYERS.map(p=>`<td>${r[p.key]?"✓":"·"}</td>`).join("")}</tr>`}
      monthTable.innerHTML=h;rewardPageStars.textContent=s.stars;
    }
    function openRewards(){closeDrawerFn();buildRewards();rewardsPage.classList.add("open")}


    async function createParentStudentAccount(event){
      event.preventDefault();
      signupError.textContent="";
      const name=signupStudentName.value.trim();
      const age=Number(signupStudentAge.value)||7;
      const batch=signupBatch.value;
      const inviteCode=signupInviteCode.value.trim().toUpperCase();
      const studentId=normalizeStudentId(signupStudentId.value);
      const email=`${studentId}@${STUDENT_LOGIN_DOMAIN}`;
      const password=signupPassword.value;
      const password2=signupPassword2.value;
      const parent=signupParentName.value.trim();

      if(password!==password2){
        signupError.textContent="Die Passwörter stimmen nicht überein.";
        return;
      }
      signupSubmitButton.disabled=true;
      signupSubmitButton.textContent="Erstellen…";
      let user=null;
      try{
        const cred=await auth.createUserWithEmailAndPassword(email,password);
        user=cred.user;
        const uid=user.uid;

        await db.collection("members").doc(uid).set({
          name,age,avatar:"🌷",batch,role:"student",studentId,email,inviteCode
        });
        await db.collection("progress").doc(uid).set({
          userId:uid,batch,records:{},stars:0,surahs:0,asma:0,words:0,duas:0
        });
        await db.collection("privateProfiles").doc(uid).set({parent});

        signupModal.classList.add("hidden");
        showToast("Konto erstellt ✓");
        // Firebase keeps the user signed in on this device by default.
      }catch(e){
        signupError.textContent=friendlyError(e);
        if(user){
          try{await user.delete()}catch(_){}
        }
      }finally{
        signupSubmitButton.disabled=false;
        signupSubmitButton.textContent="Konto erstellen";
      }
    }

    loginForm.addEventListener("submit",async e=>{
      e.preventDefault();loginError.textContent="";loginButton.disabled=true;loginButton.textContent="Anmelden…";
      try{await auth.signInWithEmailAndPassword(loginIdentifierToEmail(loginEmail.value),loginPassword.value)}
      catch(err){loginError.textContent=friendlyError(err)}
      finally{loginButton.disabled=false;loginButton.textContent="Anmelden"}
    });

    openSignupButton.onclick=()=>{
      signupForm.reset();signupStudentAge.value=7;signupError.textContent="";
      signupModal.classList.remove("hidden");
    };
    closeSignupModal.onclick=()=>signupModal.classList.add("hidden");
    signupModal.addEventListener("click",e=>{if(e.target===signupModal)signupModal.classList.add("hidden")});
    signupForm.addEventListener("submit",createParentStudentAccount);


    teacherRefresh.onclick=loadTeacherDashboard;
    saveTeacherDescription.onclick=saveTeacherDescriptionData;
    teacherOpenBatches.onclick=openStudents;
    teacherAddStudent.onclick=()=>{
      selectedBatch="Batch 1";
      newStudentBatch.value="Batch 1";
      showStudentModal();
    };
    teacherOpenTrackers.onclick=()=>{
      teacherDashboard.classList.remove("open");
      downloadsPage.classList.add("open");
    };
    teacherLogout.onclick=async()=>auth.signOut();

    logoutButton.onclick=async()=>{closeDrawerFn();await auth.signOut()};
    studentForm.addEventListener("submit",createStudentAccount);
    closeStudentModal.onclick=()=>studentModal.classList.add("hidden");
    studentModal.addEventListener("click",e=>{if(e.target===studentModal)studentModal.classList.add("hidden")});

    menuBtn.onclick=openDrawer;closeDrawer.onclick=closeDrawerFn;drawerBackdrop.onclick=closeDrawerFn;
    profileBtn.onclick=openOwnProfile;drawerProfile.onclick=openOwnProfile;navProfile.onclick=openOwnProfile;
    saveProfile.onclick=saveProfileData;closeProfile.onclick=()=>{profilePage.classList.remove("open");displayState=ownState;render()};
    drawerStudents.onclick=openStudents;closeStudents.onclick=()=>{studentsPage.classList.remove("open");displayState=ownState;render();if(isAdmin)showTeacherDashboard()};
    drawerDownloads.onclick=()=>{closeDrawerFn();profilePage.classList.remove("open");studentsPage.classList.remove("open");rewardsPage.classList.remove("open");downloadsPage.classList.add("open")};
    closeDownloads.onclick=()=>{downloadsPage.classList.remove("open");if(isAdmin)showTeacherDashboard()};
    showAllBatches.onclick=renderBatchOverview;addStudentButton.onclick=showStudentModal;
    navRewards.onclick=openRewards;drawerRewards.onclick=openRewards;closeRewards.onclick=()=>{rewardsPage.classList.remove("open");displayState=ownState;render();if(isAdmin)showTeacherDashboard()};
    profileBadgesButton.onclick=()=>{profilePage.classList.remove("open");openRewards()};
    navHome.onclick=()=>{displayState=ownState;render();scrollTo({top:0,behavior:"smooth"})};
    navGarden.onclick=()=>gardenSection.scrollIntoView({behavior:"smooth"});
    navPrayers.onclick=()=>prayerSection.scrollIntoView({behavior:"smooth"});
    document.querySelectorAll("[data-home]").forEach(b=>b.onclick=()=>{closeDrawerFn();displayState=ownState;render();scrollTo({top:0,behavior:"smooth"})});
    document.querySelectorAll("[data-scroll]").forEach(b=>b.onclick=()=>{closeDrawerFn();$(b.dataset.scroll.slice(1)).scrollIntoView({behavior:"smooth"})});

    facebookLink.href=FACEBOOK_URL;facebookHint.classList.add("hidden");
    BATCHES.forEach(b=>{const o=document.createElement("option");o.value=o.textContent=b;newStudentBatch.appendChild(o);const s=document.createElement("option");s.value=s.textContent=b;signupBatch.appendChild(s)});

    auth.onAuthStateChanged(async user=>{
      profilePage.classList.remove("open");studentsPage.classList.remove("open");rewardsPage.classList.remove("open");
      if(!user){
        currentUser=null;ownState=null;displayState=null;teacherDashboard.classList.remove("open");studentApp.style.display="none";studentNav.style.display="none";authScreen.classList.remove("hidden");syncPill.classList.add("hidden");
        loginPassword.value="";return;
      }
      try{await initializeSession(user)}
      catch(e){
        authScreen.classList.remove("hidden");loginError.textContent=friendlyError(e);
        try{await auth.signOut()}catch(_){}
      }
    });
  </script>

  <script>
    if ("serviceWorker" in navigator) {
      window.addEventListener("load", () => {
        navigator.serviceWorker.register("./service-worker.js").catch(console.error);
      });
    }
  </script>

</body>
</html>
