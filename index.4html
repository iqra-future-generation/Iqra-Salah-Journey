  <section class="modal-backdrop hidden" id="signupModal">
    <form class="modal-card" id="signupForm">
      <div class="modal-title"><h2>Schülerkonto erstellen</h2><button class="modal-close" id="closeSignupModal" type="button">×</button></div>
      <p style="text-align:left">Eltern erstellen hier einmalig das Konto. Danach bleibt die Anmeldung auf diesem Gerät gespeichert, bis man sich abmeldet.</p>
      <label>Name des Kindes<input id="signupStudentName" required></label>
      <label>Alter<input id="signupStudentAge" type="number" min="3" max="18" value="7" required></label>
      <label>Batch<select id="signupBatch"></select></label>
      <label>Batch-Einladungscode<input id="signupInviteCode" type="text" autocomplete="off" required></label>
      <label>Student-ID<input id="signupStudentId" type="text" placeholder="z. B. maryam-b1" pattern="[A-Za-z0-9._-]{3,30}" required></label>
      <div class="auth-note" style="text-align:left;margin-top:6px">Nur Buchstaben, Zahlen, Punkt, Unterstrich oder Bindestrich. Keine Leerzeichen.</div>
      <label>Passwort<input id="signupPassword" type="password" minlength="6" required></label>
      <label>Passwort wiederholen<input id="signupPassword2" type="password" minlength="6" required></label>
      <label>Name der Eltern<input id="signupParentName" required></label>
      <button class="auth-submit" id="signupSubmitButton" type="submit">Konto erstellen</button>
      <div class="auth-error" id="signupError"></div>
    </form>
  </section>

  <section class="modal-backdrop hidden" id="studentModal">
    <form class="modal-card" id="studentForm">
      <div class="modal-title"><h2>Schülerkonto erstellen</h2><button class="modal-close" id="closeStudentModal" type="button">×</button></div>
      <label>Name<input id="newStudentName" required></label>
      <label>Alter<input id="newStudentAge" type="number" min="3" max="18" value="7" required></label>
      <label>Batch<select id="newStudentBatch"></select></label>
      <label>Student-ID<input id="newStudentEmail" type="text" placeholder="z. B. maryam-b1" pattern="[A-Za-z0-9._-]{3,30}" required></label>
      <div class="auth-note" style="text-align:left;margin-top:6px">Nur Buchstaben, Zahlen, Punkt, Unterstrich oder Bindestrich. Keine Leerzeichen.</div>
      <label>Start-Passwort<input id="newStudentPassword" type="password" minlength="6" required></label>
